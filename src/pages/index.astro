---
import Button from "../components/Button";
import Navbar from "../components/Navbar";

import hero from "~/assets/hero.jpg";
import Overlay from "../components/Overlay";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100..900;1,100..900&display=swap"
			rel="stylesheet"
		/>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	</head>
	<body>
		<main>
			<section
				class="flex flex-col items-center p-8 pb-32 gap-8 text-white bg-cover relative"
				style={{ "background-image": `url(${hero.src})` }}
			>
				<Navbar />
				<div
					class="flex flex-col max-w-3xl gap-8 items-center text-center z-10 relative"
				>
					<h1 class="font-bold text-6xl">
						AUTOMOTIVE REPAIRS<br />AND MAINTENANCE
					</h1>
					<p class="mb-8">
						At Schneider Automotive Services, we provide honest,
						expert automotive repair and maintenance to keep your
						vehicle running smoothly. Located in Smithville, MO, we
						proudly serve local drivers with everything from routine
						oil changes to diagnostics and full-service repairs—done
						right the first time.
					</p>
					<Button url="/contact" text="Contact Us" />
				</div>
				<Overlay />
			</section>
		</main>
	</body>
</html>
