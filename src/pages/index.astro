---
import PageLayout from "../layouts/PageLayout.astro";
import Hero from "../components/Hero";

import hero from "~/assets/hero.jpg";
---

<PageLayout>
	<Hero
		backgroundImage={hero.src}
		header="Automotive Repairs and Maintenance"
		paragraph="At Schneider Automotive Services, we provide honest, expert \
			automotive repair and maintenance to keep your vehicle running \
			smoothly. Located in Smithville, MO, we proudly serve local drivers \
			with everything from routine oil changes to diagnostics and \
			full-service repairs—done right the first time."
	/>
</PageLayout>
