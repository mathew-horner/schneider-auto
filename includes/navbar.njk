<div id="navbar-mobile">
    <a href="/"><img id="navbar-logo" class="logo-small" src="/assets/img/logo.png" /></a>
    <button id="hamburger" onclick="hamburgerClick()">
        <img id="hamburger-icon" src="/assets/img/hamburger-{{ variant }}.svg" />
    </button>
    <nav id="navbar-mobile-dropdown">
        <a class="not-button" href="/tires">TIRES</a>
        <a class="not-button" href="/about">ABOUT</a>
        <a class="button button-primary" href="/contact">CONTACT US</a>
    </nav>
    <script>
        function hamburgerClick() {
            const navbar = document.getElementById("navbar-mobile");
            const hamburgerIcon = document.getElementById("hamburger-icon");
            const expanded = navbar.classList.toggle("expanded");

            if (expanded) {
                hamburgerIcon.src = "/assets/img/hamburger-close-dark.svg";
            } else {
                hamburgerIcon.src = "/assets/img/hamburger-{{ variant }}.svg";
            }
        }
    </script>
</div>
<div id="navbar-desktop">
    <a href="/"><img class="logo-small" src="/assets/img/logo.png" /></a>
    <nav class="flex-row items-center gap-lg">
        <a href="/tires">TIRES</a>
        <a href="/about">ABOUT US</a>
        <a class="button button-primary" href="/contact">CONTACT US</a>
    </nav>
</div>
